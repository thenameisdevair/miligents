# ─── LLM ─────────────────────────────────────────────
# Development: use Cerebras (free, fast)
# Demo: switch to 0G Compute — zero code change needed
LLM_BASE_URL=https://api.cerebras.ai/v1
LLM_API_KEY=
LLM_MODEL=llama3.1-8b

# ─── Web Search ───────────────────────────────────────
TAVILY_API_KEY=

# ─── KeeperHub ────────────────────────────────────────
KEEPERHUB_API_KEY=
KEEPERHUB_MCP_URL=http://localhost:3001
KEEPERHUB_MCP_API_KEY=miligents_local

# KeeperHub live execution safety gate. Writes are blocked unless explicitly enabled.
KEEPERHUB_LIVE_EXECUTION=false
KEEPERHUB_ALLOWED_NETWORKS=sepolia
KEEPERHUB_MAX_TX_ETH=0.001
KEEPERHUB_MAX_DAILY_SPEND_ETH=0.005
KEEPERHUB_ALLOWED_CONTRACTS=
KEEPERHUB_ALLOWED_FUNCTIONS=
KEEPERHUB_ALLOW_APPROVALS=false
KEEPERHUB_MAINNET_CONFIRMED=false
KEEPERHUB_TEST_TRANSFER_ETH=0.00001

# Dedicated execution wallets for user-owned organisms.
# Format: network:0xWalletAddress:label,network:0xWalletAddress:label
# Do not put a shared user-deposit wallet here.
KEEPERHUB_WALLET_POOL=

# Hackathon judging mode: assign pre-funded execution wallets and label them
# honestly in the UI instead of requiring judges to acquire testnet ETH first.
KEEPERHUB_SPONSORED_START=false

# ─── Deploy / Wallet Auth ─────────────────────────────
FRONTEND_ORIGIN=http://localhost:8081
CORS_ORIGINS=http://localhost:8081,http://localhost:5500,http://127.0.0.1:5500
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Optional Reown AppKit project ID. The frontend can also receive this through
# window.MILIGENTS_REOWN_PROJECT_ID, ?reownProjectId=..., or localStorage.
REOWN_PROJECT_ID=

# ─── 0G Network ───────────────────────────────────────
OG_PRIVATE_KEY=
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
OG_COMPUTE_PROVIDER_ADDRESS=
OG_INFT_CONTRACT_ADDRESS=

# Network-aware balances for organism funding checks.
SEPOLIA_RPC_URL=
BASE_RPC_URL=
ETHEREUM_RPC_URL=

# ─── Uniswap ──────────────────────────────────────────
UNISWAP_API_KEY=

# ─── Wallet (Sepolia testnet) ─────────────────────────
WALLET_PRIVATE_KEY=
WALLET_ADDRESS=

# ─── Bridge Service ───────────────────────────────────
BRIDGE_PORT=3100
BRIDGE_URL=http://localhost:3100  # use http://bridge:3100 inside Docker

# ─── AXL ──────────────────────────────────────────────
# AXL — set per container (9002 originator, 9012 specialist, 9022 execution)
AXL_API_PORT=9002
OG_INFT_CONTRACT_ADDRESS=

# ─── ChromaDB ─────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data
