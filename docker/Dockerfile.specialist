FROM python:3.11-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install -r requirements.txt --no-cache-dir --timeout 120 --retries 5
COPY agents/research_specialist/ ./agents/research_specialist/
COPY axl/ ./axl/
COPY integrations/ ./integrations/
ENV PYTHONPATH=/app
CMD ["sh", "-c", "python -m axl.local_bridge & exec python -m uvicorn agents.research_specialist.server:app --host 0.0.0.0 --port 8002"]
