FROM python:3.11-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install -r requirements.txt --no-cache-dir --timeout 120 --retries 5
COPY agents/execution/ ./agents/execution/
COPY axl/ ./axl/
COPY integrations/ ./integrations/
ENV PYTHONPATH=/app
CMD ["python", "-m", "uvicorn", "agents.execution.server:app", "--host", "0.0.0.0", "--port", "8003"]
